# APP_URL: The URL where this applet is hosted.
# Used for self-referential links and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Auth + Cloud Persistence
# Get these values from your Supabase project → Settings → API.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"

# ── Supabase database setup ────────────────────────────────────────────────────
# After adding the env vars above, run ALL migrations in order in your Supabase
# project to create the required tables, functions, and Row Level Security
# policies.  Open Dashboard → SQL Editor → New query, paste each file's
# contents, and run them one at a time in the order listed below:
#
#   001_create_canvases.sql              — canvases table + RLS
#   002_create_canvas_snapshots.sql      — snapshots table + RLS
#   003_create_canvas_shares.sql         — canvas_shares table, RLS, and
#                                          get_canvas_by_share_token() RPC
#   004_create_workspaces.sql            — workspaces + workspace_members tables
#   005_create_workspace_invitations.sql — invitations table + accept RPC
#   006_workspace_canvas_permissions.sql — tighter DELETE policies for workspaces
#   007_create_canvas_comments.sql       — comments table + RLS
#   008_workspace_share_read_policy.sql  — SELECT policy so workspace members
#                                          can read shares on shared canvases
#
# All files are in supabase/migrations/.
# Skipping migrations will cause features to fail silently or with RLS errors.

# ── Error Tracking (Sentry) ───────────────────────────────────────────────────
# Both variables are optional.  When omitted the SDK is not initialised and
# the app runs normally without sending any data to Sentry.
#
# VITE_SENTRY_DSN  – browser / frontend SDK (exposed to the client by Vite)
# SENTRY_DSN       – server / backend SDK (kept server-side only)
#
# Get your DSN from sentry.io → Project → Settings → Client Keys (DSN).
# Create two separate Sentry projects (one for frontend, one for backend) or
# use the same DSN for both – either approach works.
VITE_SENTRY_DSN="https://your-key@oXXXXX.ingest.sentry.io/XXXXXXX"
SENTRY_DSN="https://your-key@oXXXXX.ingest.sentry.io/XXXXXXX"

# ── AI Assistant (Gemini) ─────────────────────────────────────────────────────
# Server-side only — intentionally NO "VITE_" prefix so this secret is never
# bundled into the browser build.  The server calls Gemini on behalf of the
# client, keeping the key fully protected.
#
# The assistant endpoint requires an authenticated Supabase session: the client
# sends its JWT and the server verifies it using VITE_SUPABASE_URL and
# VITE_SUPABASE_ANON_KEY (already required above — no extra variables needed).
#
# Deployment notes:
#   • Vercel: set GEMINI_API_KEY in your project's Environment Variables.
#             The serverless function at api/assistant.ts handles the route.
#   • Self-hosted (Railway, Fly.io, VPS): set GEMINI_API_KEY in the server
#             environment.  The Express route in server.ts handles the request.
#
# 1. Go to https://aistudio.google.com/app/apikey and create a key.
# 2. Add GEMINI_API_KEY to your environment (never commit this value).
# 3. If the variable is absent the /api/assistant route returns HTTP 503 and
#    the assistant button gracefully shows an error message.
#
# Model used: gemini-1.5-flash (v1 stable endpoint, fast and cost-effective).
GEMINI_API_KEY="your-google-ai-studio-api-key"

# ── Product Analytics (PostHog) ───────────────────────────────────────────────
# Both variables are optional.  When omitted the SDK is not initialised and
# no analytics data is sent.
#
# VITE_POSTHOG_KEY  – Project API key from PostHog → Project Settings → Project API key.
# VITE_POSTHOG_HOST – Ingestion host. Defaults to https://eu.i.posthog.com when omitted.
#                     Override to https://us.i.posthog.com or your self-hosted URL.
#
# Autocapture, session recording, and PII collection are disabled by default.
# See src/lib/analytics.ts for the full configuration and event taxonomy.
VITE_POSTHOG_KEY="phc_your_project_api_key"
VITE_POSTHOG_HOST="https://eu.i.posthog.com"
