# APP_URL: The URL where this applet is hosted.
# Used for self-referential links and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Auth + Cloud Persistence
# Get these values from your Supabase project → Settings → API.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"

# ── Supabase database setup ────────────────────────────────────────────────────
# After adding the env vars above, run the migration once in your Supabase
# project to create the `canvases` table and enable Row Level Security:
#
#   supabase/migrations/001_create_canvases.sql
#
# Open Dashboard → SQL Editor → New query, paste the file contents, and run it.

# ── Error Tracking (Sentry) ───────────────────────────────────────────────────
# Both variables are optional.  When omitted the SDK is not initialised and
# the app runs normally without sending any data to Sentry.
#
# VITE_SENTRY_DSN  – browser / frontend SDK (exposed to the client by Vite)
# SENTRY_DSN       – server / backend SDK (kept server-side only)
#
# Get your DSN from sentry.io → Project → Settings → Client Keys (DSN).
# Create two separate Sentry projects (one for frontend, one for backend) or
# use the same DSN for both – either approach works.
VITE_SENTRY_DSN="https://your-key@oXXXXX.ingest.sentry.io/XXXXXXX"
SENTRY_DSN="https://your-key@oXXXXX.ingest.sentry.io/XXXXXXX"

# ── Product Analytics (PostHog) ───────────────────────────────────────────────
# Both variables are optional.  When omitted the SDK is not initialised and
# no analytics data is sent.
#
# VITE_POSTHOG_KEY  – Project API key from PostHog → Project Settings → Project API key.
# VITE_POSTHOG_HOST – Ingestion host. Defaults to https://eu.i.posthog.com when omitted.
#                     Override to https://us.i.posthog.com or your self-hosted URL.
#
# Autocapture, session recording, and PII collection are disabled by default.
# See src/lib/analytics.ts for the full configuration and event taxonomy.
VITE_POSTHOG_KEY="phc_your_project_api_key"
VITE_POSTHOG_HOST="https://eu.i.posthog.com"
